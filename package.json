{
  "name": "cyber-security-scanner",
  "version": "2.0.0",
  "description": "CyberShield - GOATED Web Security Scanner | Electron + React + Puppeteer",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && node start.js",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.cybersecurity.security-scanner",
    "productName": "CyberShield Security Scanner",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "cross-env": "^10.1.0",
    "electron": "^26.2.1",
    "electron-builder": "^26.5.0",
    "electron-is-dev": "^2.0.0",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.29.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.263.0",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.36.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.4.0"
  }
}
